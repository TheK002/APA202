@{
    int count = 0;
}

<div class="row">
    <div class="col-lg-12 stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Category Table</h4>
                <p class="card-description">
                </p>
                <div class="table-responsive pt-3">
                    <a asp-area="AdminPanel" asp-controller="Category" asp-action="Create" class="btn btn-success btn-rounded btn-fw">Create</a>
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>
                                    #
                                </th>
                                <th>
                                    name
                                </th>
                                <th>
                                    Products
                                </th>
                                <th>
                                    Settings
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(Category category in Model)
                            {
                                <tr class="table-info">
                                    <td>
                                        <p>@(++count)</p>
                                    </td>
                                    <td>
                                        <p>@category.Name</p>
                                    </td>
                                    <td>
                                        <p>@category.Products.Count</p>
                                    </td>
                                    <td>
                                        <a class="btn btn-warning btn-rounded btn-fw">Edit</a>
                                        <a class="btn btn-danger btn-rounded btn-fw">Delete</a>
                                        <a asp-action="Detail" asp-route-id="@category.Id" class="btn btn-info btn-rounded btn-fw">Detail</a>
                                    </td>
                               
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
            
</div>